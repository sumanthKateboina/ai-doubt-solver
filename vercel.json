{
  "cleanUrls": true,
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-doubt-solver-backend-d8ot.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://ai-doubt-solver-backend-d8ot.onrender.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
