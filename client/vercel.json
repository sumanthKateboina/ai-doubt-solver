{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_BACKEND_URL/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR_RENDER_BACKEND_URL/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
